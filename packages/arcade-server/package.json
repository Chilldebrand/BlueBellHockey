{
  "name": "@bbh/arcade-server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build --workspace @bbh/arcade-core && tsc -p tsconfig.json",
    "test": "npm run build --workspace @bbh/arcade-core && vitest run",
    "smoke": "npm run build --workspace @bbh/arcade-core && tsx scripts/two-client-smoke.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@bbh/arcade-core": "*",
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "colyseus": "^0.16.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
