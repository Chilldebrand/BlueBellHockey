{
  "name": "bbellhockey",
  "version": "0.1.0",
  "private": true,
  "description": "Online 3v3 arcade hockey",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @bbh/shared",
    "dev": "npm run build:shared && concurrently -n server,client -c blue,green \"npm run dev --workspace @bbh/server\" \"npm run dev --workspace @bbh/client\"",
    "dev:server": "npm run dev --workspace @bbh/server",
    "dev:client": "npm run dev --workspace @bbh/client",
    "test": "npm run test --workspace @bbh/shared",
    "typecheck": "tsc -b packages/shared packages/server packages/client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
