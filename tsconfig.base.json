{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@bbh/arcade-core": ["packages/arcade-core/src/index.ts"],
      "@bbh/arcade-server": ["packages/arcade-server/src/index.ts"],
      "@bbh/arcade-client": ["packages/arcade-client/src/main.tsx"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
